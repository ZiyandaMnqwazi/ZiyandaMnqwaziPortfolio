<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Ziyanda Mnqwazi | Data &amp; Software Portfolio</title>
    <meta name="description" content="Ziyanda Mnqwazi — Digital Analytics Intern and Software Developer. GA4, GTM, Looker Studio, C#, Python. Based in Cape Town." />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.css" rel="stylesheet" />

    <link href="~/css/site.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/ZiyandaMnqwaziPortfolio.styles.css" rel="stylesheet" asp-append-version="true" />
</head>

<body>

    <nav class="zn-nav" aria-label="Main navigation">
        <div class="zn-nav-inner" id="navInner">

            <a class="zn-brand" asp-area="" asp-controller="Home" asp-action="Index">
                Ziyanda <em>Mnqwazi</em>
            </a>

            <ul class="zn-links">
                <li><a asp-area="" asp-controller="Home" asp-action="Index">Home</a></li>
                <li><a href="#about">About</a></li>
                <li><a href="#projects">Projects</a></li>
                <li><a href="#contact">Contact</a></li>
                <li>
                    <a href="#certificates" class="cert-link">
                        <i class="fas fa-certificate me-1"></i>Certificates
                    </a>
                </li>
            </ul>

            <div class="zn-socials">
                <a href="https://linkedin.com/in/ziyanda-mnqwazi-4439782a0"
                   target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
                    <i class="fab fa-linkedin"></i>
                </a>
                <a href="https://github.com/ZiyandaMnqwazi"
                   target="_blank" rel="noopener noreferrer" aria-label="GitHub">
                    <i class="fab fa-github"></i>
                </a>
            </div>

            <button class="zn-toggle" id="navToggle"
                    aria-label="Toggle navigation menu"
                    aria-expanded="false">
                <span class="bar"></span>
                <span class="bar"></span>
                <span class="bar"></span>
            </button>

        </div>
    </nav>

    <!-- Mobile menu -->
    <div class="zn-mobile-menu" id="mobileMenu" role="navigation" aria-label="Mobile navigation">
        <a asp-area="" asp-controller="Home" asp-action="Index">Home</a>
        <a href="#about">About</a>
        <a href="#projects">Projects</a>
        <a href="#contact">Contact</a>
        <a href="#certificates" class="cert-link">
            <i class="fas fa-certificate me-1"></i>Certificates
        </a>
        <div class="zn-mobile-menu-socials">
            <a href="https://linkedin.com/in/ziyanda-mnqwazi-4439782a0"
               target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
                <i class="fab fa-linkedin"></i>
            </a>
            <a href="https://github.com/ZiyandaMnqwazi"
               target="_blank" rel="noopener noreferrer" aria-label="GitHub">
                <i class="fab fa-github"></i>
            </a>
        </div>
    </div>

    <div class="container">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="zn-footer">
        <span class="footer-name">Ziyanda <em>Mnqwazi</em></span>
        <span class="footer-tagline">Digital Analytics &amp; Software Development</span>

        <nav class="footer-links" aria-label="Footer navigation">
            <a asp-controller="Home" asp-action="Index">Home</a>
            <a href="#about">About</a>
            <a href="#projects">Projects</a>
            <a href="#contact">Contact</a>
            <a href="#certificates">Certificates</a>
        </nav>

        <div class="footer-socials">
            <a href="https://linkedin.com/in/ziyanda-mnqwazi-4439782a0"
               target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
                <i class="fab fa-linkedin"></i>
            </a>
            <a href="https://github.com/ZiyandaMnqwazi"
               target="_blank" rel="noopener noreferrer" aria-label="GitHub">
                <i class="fab fa-github"></i>
            </a>
        </div>

        <p class="footer-copy">
            © 2025 Ziyanda Mnqwazi · Built with 💖 using ASP.NET &amp; Dapper
        </p>
    </footer>

    <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 1100">
        <div id="contactToast"
             class="toast zn-toast align-items-center border-0"
             role="alert"
             aria-live="assertive"
             aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body"></div>
                <button type="button"
                        class="btn-close btn-close-white me-2 m-auto"
                        data-bs-dismiss="toast"
                        aria-label="Close"></button>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            @if (TempData["Message"] != null)
            {
                    <text>
                    var toastEl = document.getElementById('contactToast');
                    toastEl.querySelector('.toast-body').textContent = '@TempData["Message"]';
                    new bootstrap.Toast(toastEl).show();
                    </text>
            }
            else if (TempData["Error"] != null)
            {
                    <text>
                    var toastEl = document.getElementById('contactToast');
                    toastEl.querySelector('.toast-body').textContent = '@TempData["Error"]';
                    new bootstrap.Toast(toastEl).show();
                    </text>
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>