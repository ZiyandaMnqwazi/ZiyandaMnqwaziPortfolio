<!-- ═══ PROJECTS ════════════════════════════════════════ -->
<section class="projects-section full-bleed" id="projects">
    <div class="container">

        <span class="section-eyebrow">Projects</span>
        <h2 class="section-heading light">Things I have built</h2>

        <div class="projects-grid">

            <!-- Mental Wellness Dashboard — featured, full width -->
            <div class="project-card featured solo" data-aos="fade-up">

                <div class="project-content">
                    <div class="project-card-icon gold">
                        <i class="fas fa-chart-pie"></i>
                    </div>
                    <p class="project-title">
                        Mental Wellness &amp; Screentime Dashboard
                    </p>
                    <p class="project-desc">
                        Analysed relationships between screentime, mental wellness
                        and lifestyle habits across different age groups, genders
                        and working environments. Used Python for data cleaning
                        and Power BI for interactive visualisation — covering
                        sleep patterns, stress levels, physical activity and
                        productivity. Built in two dashboard pages: Screentime
                        &amp; Activity, and Wellness &amp; Lifestyle.
                    </p>
                    <div class="project-tools">
                        <span class="project-tool-tag">Python</span>
                        <span class="project-tool-tag">Pandas</span>
                        <span class="project-tool-tag">Seaborn</span>
                        <span class="project-tool-tag">Power BI</span>
                        <span class="project-tool-tag">VS Code</span>
                        <span class="project-tool-tag">GitHub</span>
                    </div>
                    <div class="project-links">
                        <a href="https://github.com/ZiyandaMnqwazi"
                           target="_blank" rel="noopener noreferrer"
                           class="project-link-btn">
                            <i class="fab fa-github"></i> GitHub
                        </a>
                    </div>
                </div>

                <div class="project-preview">
                    <img src="~/images/screenshot 2025-09-25 022022.png" />
                         alt="Mental Wellness Dashboard — Screentime and Exercise Analysis" />
                </div>

            </div>

            <!-- Ward Management System -->
            <div class="project-card collab" data-aos="fade-up" data-aos-delay="80">
                <div class="project-card-icon pink">
                    <i class="fas fa-hospital"></i>
                </div>
                <p class="project-title">Ward Management System</p>
                <p class="project-desc">
                    A secure ward management system with 5 user roles — Admin,
                    Doctor, Nurse, Script Manager and Consumable Manager.
                    Built with ASP.NET MVC, Dapper ORM and SQL Server with a
                    focus on clean role-based access and efficient hospital
                    workflow management.
                </p>
                <div class="project-tools">
                    <span class="project-tool-tag">C# ASP.NET MVC</span>
                    <span class="project-tool-tag">Dapper ORM</span>
                    <span class="project-tool-tag">SQL Server</span>
                    <span class="project-tool-tag">Role-Based Access</span>
                </div>
                <div class="project-links">
                    <a href="https://github.com/ZiyandaMnqwazi/Ward-Management-System"
                       target="_blank" rel="noopener noreferrer"
                       class="project-link-btn">
                        <i class="fab fa-github"></i> GitHub
                    </a>
                </div>
            </div>

            <!-- Pharmacy Management System -->
            <div class="project-card collab" data-aos="fade-up" data-aos-delay="120">
                <div class="project-card-icon teal">
                    <i class="fas fa-pills"></i>
                </div>
                <p class="project-title">Pharmacy Management System</p>
                <p class="project-desc">
                    A web-based pharmacy system supporting prescription uploads,
                    medication ordering and stock management. Features role-based
                    access for Managers, Pharmacists and Customers — enabling
                    efficient prescription dispensing, medication tracking and
                    improved pharmacy workflow.
                </p>
                <div class="project-tools">
                    <span class="project-tool-tag">Web-Based</span>
                    <span class="project-tool-tag">Role-Based Access</span>
                    <span class="project-tool-tag">Stock Management</span>
                    <span class="project-tool-tag">Prescription Tracking</span>
                </div>
                <div class="project-links">
                    <a href="https://github.com/ZiyandaMnqwazi/Pharmacy-Management-System"
                       target="_blank" rel="noopener noreferrer"
                       class="project-link-btn">
                        <i class="fab fa-github"></i> GitHub
                    </a>
                </div>
            </div>

        </div>

        <p style="text-align:center; margin-top: 40px; font-size: 0.82rem;
                  color: rgba(247,240,244,0.25);">
            More projects in progress — including real GTM &amp; GA4
            implementations from my internship.
        </p>

    </div>
</section>
<!-- ═══ CONTACT ═════════════════════════════════════════ -->
<section class="contact-section full-bleed" id="contact">
    <div class="container">
        <div class="row g-5 align-items-start">

            <div class="col-lg-5" data-aos="fade-up">
                <span class="section-eyebrow">Contact</span>
                <h2 class="section-heading light">Let's talk data, tech, or both</h2>
                <p class="contact-blurb">
                    I'm drawn to work that sits at the intersection of
                    <strong>data, tech and real problem-solving</strong>.
                    If you're building something interesting or have a challenge
                    that needs someone who thinks in systems let's talk.
                </p>
                <p class="contact-blurb mt-3">
                    Open to opportunities in <strong>digital analytics</strong>,
                    <strong>software development</strong>, and roles where
                    the two overlap.
                </p>
                <div class="hero-socials mt-4">
                    <a href="https://linkedin.com/in/ziyanda-mnqwazi-4439782a0"
                       target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
                        <i class="fab fa-linkedin"></i>
                    </a>
                    <a href="https://github.com/ZiyandaMnqwazi"
                       target="_blank" rel="noopener noreferrer" aria-label="GitHub">
                        <i class="fab fa-github"></i>
                    </a>
                </div>
            </div>

            <div class="col-lg-7" data-aos="fade-up" data-aos-delay="100">
                <div class="contact-form-card">
                    <form asp-action="ContactForm" method="post" novalidate>

                        <div class="mb-4">
                            <label for="name" class="form-label">Your Name</label>
                            <input type="text" id="name" name="name"
                                   class="form-control"
                                   placeholder="Enter your name" required />
                        </div>

                        <div class="mb-4">
                            <label for="email" class="form-label">Your Email</label>
                            <input type="email" id="email" name="email"
                                   class="form-control"
                                   placeholder="your@email.com" required />
                        </div>

                        <div class="mb-4">
                            <label for="message" class="form-label">Your Message</label>
                            <textarea id="message" name="message"
                                      class="form-control" rows="5"
                                      placeholder="Tell me what you're working on..."
                                      required></textarea>
                        </div>

                        <button type="submit" class="btn-pink w-100">
                            <i class="fas fa-paper-plane"></i>
                            Send Message
                        </button>

                    </form>
                </div>
            </div>

        </div>
    </div>
</section>