<!-- ═══ WHAT I DO ══════════════════════════════════════ -->
<section class="what-section">
    <span class="section-eyebrow">What I do</span>
    <h2 class="section-heading">I work where data meets product</h2>

    <div class="row g-4">
        @foreach (var area in new[] {
                new {
                Icon  = "fas fa-tags",
                Title = "Tracking & Analytics",
                Desc  = "Setting up and auditing tracking in Google Tag Manager, analysing user behaviour in GA4, and making sure the data going in is actually trustworthy."
                },
                new {
                Icon  = "fas fa-chart-bar",
                Title = "Dashboards & Reporting",
                Desc  = "Building Looker Studio and Power BI dashboards that don't just display numbers — they answer the questions stakeholders are actually asking."
                },
                new {
                Icon  = "fas fa-code",
                Title = "Development & UX",
                Desc  = "Crossing into web development in C#, Python and JavaScript, with UX thinking through wireframing and Balsamiq. I understand how data lives inside a product, not just how to report on it from the outside."
                }
                })
        {
            <div class="col-md-4" data-aos="fade-up">
                <div class="do-card">
                    <div class="do-card-icon">
                        <i class="@area.Icon"></i>
                    </div>
                    <p class="do-card-title">@area.Title</p>
                    <p class="do-card-desc">@area.Desc</p>
                </div>
            </div>
        }
    </div>
</section>

<!-- ═══ SKILLS ═════════════════════════════════════════ -->
<section class="skills-section full-bleed">
    <div class="container">
        <span class="section-eyebrow">Skills</span>
        <h2 class="section-heading light">My technical toolkit</h2>

        <div class="row g-5">
            <div class="col-md-6" data-aos="fade-up">
                <span class="skills-col-label">Analytics &amp; Data</span>
                @foreach (var s in new[] {
                                "Google Analytics 4 (GA4)",
                                "Google Tag Manager (GTM)",
                                "Looker Studio",
                                "Power BI",
                                "SQL",
                                "Data Visualisation"
                                })
                {
                    <span class="skill-pill gold">
                        <span class="dot"></span>@s
                    </span>
                }
            </div>

            <div class="col-md-6" data-aos="fade-up" data-aos-delay="100">
                <span class="skills-col-label">Development &amp; Design</span>
                @foreach (var s in new[] {
                                "C# & .NET",
                                "Python",
                                "JavaScript",
                                "HTML & CSS",
                                "Dapper ORM",
                                "Git & GitHub",
                                "UX & Wireframing",
                                "Balsamiq"
                                })
                {
                    <span class="skill-pill">
                        <span class="dot"></span>@s
                    </span>
                }
            </div>
        </div>
    </div>
</section>

